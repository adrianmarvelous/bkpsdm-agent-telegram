# TEKO-CAK Configuration
# Copy file ini ke .env dan isi credential-nya
# cp .env.example .env

TEKOCAK_URL=https://teko-cak.surabaya.go.id
TEKOCAK_USERNAME=your_username
TEKOCAK_PASSWORD=your_password
TEKOCAK_TAHUN=2026
TEKOCAK_HEADLESS=false

# Filter NIP (opsional) — proses hanya NIP tertentu, pisah dengan koma
# Kosongkan untuk proses semua NIP dari master-pegawai.csv
# TEKOCAK_FILTER_NIP=3578041306950011,3578016205030003

# Key enkripsi CSV (AES-256) — wajib diisi!
CSV_ENCRYPT_KEY=ganti_dengan_key_rahasia
