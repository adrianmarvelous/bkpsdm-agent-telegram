# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===== OpenRouter AI Configuration =====
# Dapatkan API Key di https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model AI yang digunakan (opsional)
# Daftar model: https://openrouter.ai/models
# Default: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# URL aplikasi (untuk referer header OpenRouter)
APP_URL=https://github.com/agent-bkpsdm-telegram

# ===== MySQL Database Configuration =====
# Database Website — legacy DB_ prefix juga didukung
WEB_HOST=localhost
WEB_PORT=3306
WEB_USER=root
WEB_PASSWORD=
WEB_NAME=bkpsdm
WEB_POOL_LIMIT=10

# Database SIJAKA — opsional, hapus/tidak diisi jika tidak dipakai
SIJAKA_HOST=localhost
SIJAKA_PORT=3306
SIJAKA_USER=root
SIJAKA_PASSWORD=
SIJAKA_NAME=bkpsdm_secondary
SIJAKA_POOL_LIMIT=5
SIJAKA_POOL_LIMIT=5
DB2_POOL_LIMIT=5

# ===== Security =====
# Chat ID yang diizinkan menggunakan bot (pisahkan dengan koma jika lebih dari satu)
# Cara dapatkan chat ID: kirim pesan ke bot, kemudian kirim /myid
# Atau gunakan bot @userinfobot di Telegram
ALLOWED_CHAT_IDS=
